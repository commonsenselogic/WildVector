# WildVector needs no environment variables to run the three built-in animals.

# Optional: a paid Open-Meteo plan raises refresh_environment.py's rate limits.
OPEN_METEO_API_KEY=

# Optional: only needed if you install requirements for the Copernicus GLORYS
# marine-current enrichment path (--source glorys in refresh_environment.py).
COPERNICUSMARINE_SERVICE_USERNAME=
COPERNICUSMARINE_SERVICE_PASSWORD=
